---
import type { Alternate } from '../lib/alternates';

interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: string;
  ogUrl: string;
  ogDescription: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: object | object[];
  alternates?: Alternate[];
  articleMeta?: ArticleMeta;
}

const {
  title,
  description,
  lang,
  ogUrl,
  ogDescription,
  ogImage,
  ogType = 'website',
  noindex = false,
  jsonLd,
  alternates = [],
  articleMeta,
} = Astro.props;

const siteUrl = 'https://legacydram.com';
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href)
  : `${siteUrl}/og-default.png`;
const gaId = import.meta.env.PUBLIC_GA_ID ?? 'G-D1351D30XH';
const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>
    <link rel="canonical" href={ogUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="LegacyDram" />
    {ogType === 'article' && articleMeta?.publishedTime && (
      <meta property="article:published_time" content={articleMeta.publishedTime} />
    )}
    {ogType === 'article' && articleMeta?.modifiedTime && (
      <meta property="article:modified_time" content={articleMeta.modifiedTime} />
    )}
    {ogType === 'article' && articleMeta?.author && (
      <meta property="article:author" content={articleMeta.author} />
    )}
    {ogType === 'article' && articleMeta?.section && (
      <meta property="article:section" content={articleMeta.section} />
    )}
    {ogType === 'article' && articleMeta?.tags && articleMeta.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {jsonLdArray.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <slot name="head" />
    <style>
      @import "tailwindcss";

      :root,
      [data-theme="dark"] {
        --bg-primary: #14110E;
        --bg-card: #1F1A14;
        --text-primary: #E8DEC8;
        --text-secondary: #C2B392;
        --text-label: #9B8868;
        --text-muted: #6B5C46;
        --text-separator: #332B22;
        --link-color: #D4A86A;
        --accent-primary: #B98432;
        --accent-warm: #8B4A2B;
        --accent-green: #4A6B4F;
      }

      [data-theme="light"] {
        --bg-primary: #F5EFE3;
        --bg-card: #FFFFFF;
        --text-primary: #1F1611;
        --text-secondary: #3E2E1F;
        --text-label: #6B5742;
        --text-muted: #998874;
        --text-separator: #DCD0BE;
        --link-color: #8B5A24;
        --accent-primary: #A66F1F;
        --accent-warm: #8B4A2B;
        --accent-green: #4A6B4F;
      }

      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        margin: 0;
        min-height: 100vh;
        transition: background-color 0.2s, color 0.2s;
      }

      h1, h2, h3 {
        font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
      }

      a {
        color: var(--link-color);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .theme-toggle {
        background: none;
        border: 1px solid var(--text-separator);
        color: var(--text-label);
        cursor: pointer;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 1rem;
        line-height: 1;
        transition: color 0.2s, border-color 0.2s;
      }
      .theme-toggle:hover {
        color: var(--text-primary);
        border-color: var(--text-label);
      }

      [data-theme="dark"] .icon-sun { display: inline; }
      [data-theme="dark"] .icon-moon { display: none; }
      [data-theme="light"] .icon-sun { display: none; }
      [data-theme="light"] .icon-moon { display: inline; }

      @media (max-width: 640px) {
        main {
          padding: 1.5rem 1rem !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function applyState(theme) {
          var isDark = theme === 'dark';
          btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
          var label = isDark ? 'Switch to light theme' : 'Switch to dark theme';
          var jaLabel = isDark ? 'ライトテーマに切替' : 'ダークテーマに切替';
          var langAttr = document.documentElement.getAttribute('lang') || 'en';
          btn.setAttribute('aria-label', langAttr === 'ja' ? jaLabel : label);
        }
        applyState(document.documentElement.getAttribute('data-theme') || 'dark');
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme') || 'dark';
          var next = current === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          applyState(next);
        });
      });
    </script>
  </body>
</html>
