---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout
  title="Page Not Found — LegacyDram"
  description="The page you're looking for doesn't exist."
  lang="en"
  ogUrl="https://legacydram.com/404"
  ogDescription="Page not found."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>
  <Nav lang="en" current="" />

  <main style="max-width: 720px; margin: 0 auto; padding: 8rem 2rem; text-align: center;">
    <p style="font-size: 4rem; margin-bottom: 0.5rem; opacity: 0.3;">404</p>
    <h1 style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.75rem; font-weight: 600; margin-bottom: 1rem;">
      The cask is empty
    </h1>
    <p style="color: var(--text-muted); margin-bottom: 2.5rem; line-height: 1.7;">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/" style="color: var(--link-color); text-decoration: none; padding: 0.5rem 1.25rem; border: 1px solid var(--text-separator); border-radius: 20px; font-size: 0.9rem;">
        Home
      </a>
      <a href="/blog/" style="color: var(--link-color); text-decoration: none; padding: 0.5rem 1.25rem; border: 1px solid var(--text-separator); border-radius: 20px; font-size: 0.9rem;">
        Articles
      </a>
      <a href="/ja/" style="color: var(--link-color); text-decoration: none; padding: 0.5rem 1.25rem; border: 1px solid var(--text-separator); border-radius: 20px; font-size: 0.9rem;">
        Japanese
      </a>
    </div>
  </main>
</BaseLayout>
